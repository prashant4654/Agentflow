# Agentflow Configuration
# Copy this file to .env and customize the values

# ============================================================================
# Logging Configuration
# ============================================================================

# Enable debug logging (set to 1, true, yes, or on)
# When enabled, sets log level to DEBUG and uses detailed format
# AGENTFLOW_DEBUG=1

# Set specific log level (overridden by AGENTFLOW_DEBUG if set)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# AGENTFLOW_LOG_LEVEL=INFO

# Set log output format
# Options: simple, detailed, json
# AGENTFLOW_LOG_FORMAT=simple

# Enable reasoning capture in logs (set to 1, true, yes, or on)
# When enabled, logs ReasoningBlock content from agent execution
# AGENTFLOW_LOG_REASONING=1

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# OpenAI API Key (required for OpenAI models)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (required for Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API Key (required for Gemini models)
# GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# Database & Storage Configuration
# ============================================================================

# PostgreSQL connection string (for PgCheckpointer)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentflow

# Redis connection URL (for caching with PgCheckpointer)
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Message Broker Configuration
# ============================================================================

# Kafka brokers (comma-separated)
# KAFKA_BROKERS=localhost:9092

# RabbitMQ connection URL
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ============================================================================
# Monitoring & Error Tracking
# ============================================================================

# Sentry DSN (for error tracking)
# SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# ID Generation Configuration
# ============================================================================

# Type of ID to generate for messages and tool calls
# Options: string (UUID), int (32-bit), bigint (64-bit)
# GENERATED_ID_TYPE=string

# ============================================================================
# Example Usage
# ============================================================================
#
# 1. Development with full debug logging:
#    AGENTFLOW_DEBUG=1
#    AGENTFLOW_LOG_REASONING=1
#    AGENTFLOW_LOG_FORMAT=detailed
#
# 2. Production with structured JSON logging:
#    AGENTFLOW_LOG_LEVEL=INFO
#    AGENTFLOW_LOG_FORMAT=json
#
# 3. Testing with minimal logging:
#    AGENTFLOW_LOG_LEVEL=WARNING
#    AGENTFLOW_LOG_FORMAT=simple
